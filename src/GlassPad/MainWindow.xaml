<Window x:Class="GlassPad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GlassPad"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Left="0" Top="0">

    <Window.Resources>
        <!-- Circular FAB style -->
        <Style x:Key="FabBtn" TargetType="Button">
            <Setter Property="Width"           Value="44"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="18"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded small button style (panels) -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Gamepad button canvas (alpha=0 areas pass touch through to game) -->
        <Canvas x:Name="TouchCanvas" Background="Transparent"/>

        <!-- Edit mode overlay (managed by LayoutEditor, inactive by default) -->
        <Canvas x:Name="EditCanvas" Background="Transparent" IsHitTestVisible="False"/>

        <!-- ── Top-center control hub ──────────────────────────────── -->
        <!-- HubCanvas sits directly in Grid so HorizontalAlignment="Center" is unambiguous -->
        <Canvas x:Name="HubCanvas"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Width="230" Height="200"
                Margin="0,8,0,0"
                Background="Transparent">

            <!-- Quit (top, hidden) -->
            <Button x:Name="CloseAppBtn"
                    Canvas.Left="121" Canvas.Top="28"
                    Style="{StaticResource FabBtn}"
                    Background="#CCFF3333"
                    Content="✕"
                    ToolTip="Quit GlassPad"
                    Visibility="Collapsed"
                    Click="CloseAppBtn_Click"/>

            <!-- Edit layout (right, hidden) -->
            <Button x:Name="EditModeBtn"
                    Canvas.Left="181" Canvas.Top="88"
                    Style="{StaticResource FabBtn}"
                    Background="#CC4080FF"
                    Content="✎"
                    ToolTip="Edit button layout"
                    Visibility="Collapsed"
                    Click="EditModeBtn_Click"/>

            <!-- About (bottom, hidden) -->
            <Button x:Name="InfoBtn"
                    Canvas.Left="121" Canvas.Top="148"
                    Style="{StaticResource FabBtn}"
                    Background="#CC208060"
                    Content="ℹ"
                    ToolTip="About GlassPad"
                    Visibility="Collapsed"
                    Click="InfoBtn_Click"/>

            <!-- Disable overlay (always visible) — center=87, pair midpoint=115=canvas center -->
            <Button x:Name="DisableButton"
                    Canvas.Left="65" Canvas.Top="88"
                    Style="{StaticResource FabBtn}"
                    Background="#CCE07030"
                    Opacity="{Binding Value, ElementName=OpacitySlider}"
                    Content="⊘"
                    ToolTip="Hold to disable overlay"/>

            <!-- FAB main toggle (always visible) — center=143 -->
            <Button x:Name="FabButton"
                    Canvas.Left="121" Canvas.Top="88"
                    Style="{StaticResource FabBtn}"
                    Background="#CC5050A0"
                    Opacity="{Binding Value, ElementName=OpacitySlider}"
                    Content="≡"
                    ToolTip="Menu"
                    Click="FabButton_Click"/>
        </Canvas>

        <!-- Edit panel: sits below HubCanvas (8 margin + 200 height + 4 gap = 212) -->
        <Border x:Name="EditPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,212,0,0"
                Visibility="Collapsed"
                Background="#DD1a1a2e"
                CornerRadius="12"
                Padding="16,12"
                MinWidth="260">
            <StackPanel>
                <TextBlock Text="Button Opacity"
                           Foreground="#AAC0D0FF"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,6"/>
                <Slider x:Name="OpacitySlider"
                        Minimum="0.15"
                        Maximum="1.0"
                        Value="1.0"
                        SmallChange="0.05"
                        LargeChange="0.1"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="True"
                        ValueChanged="OpacitySlider_ValueChanged"/>

                <TextBlock Text="D-Pad Mode"
                           Foreground="#AAC0D0FF"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Margin="0,10,0,6"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="Dpad4Btn"
                            Style="{StaticResource PillBtn}"
                            Content="4-Way"
                            Tag="4"
                            Width="106" Height="30"
                            Background="#CC208060"
                            Margin="0,0,8,0"
                            Click="DpadModeBtn_Click"/>
                    <Button x:Name="Dpad8Btn"
                            Style="{StaticResource PillBtn}"
                            Content="8-Way"
                            Tag="8"
                            Width="106" Height="30"
                            Background="#80406090"
                            Click="DpadModeBtn_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Button Style="{StaticResource PillBtn}"
                            Content="💾  Save"
                            Width="106" Height="32"
                            Background="#CC208060"
                            Margin="0,0,8,0"
                            Click="SaveLayout_Click"/>
                    <Button Style="{StaticResource PillBtn}"
                            Content="↺  Reset"
                            Width="106" Height="32"
                            Background="#CC804020"
                            Click="ResetLayout_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Save confirmation dialog ────────────────────────────── -->
        <Border x:Name="SaveConfirmPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#F01a1a2e"
                CornerRadius="14"
                Padding="28,22"
                MinWidth="280"
                Visibility="Collapsed"
                Panel.ZIndex="60">
            <StackPanel>
                <TextBlock Text="✓  Layout Saved"
                           Foreground="#88EEBB"
                           FontSize="16"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Close edit mode?"
                           Foreground="#AAC0D0FF"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource PillBtn}"
                            Content="Yes"
                            Width="100" Height="34"
                            FontSize="13"
                            Background="#CC208060"
                            Margin="0,0,10,0"
                            Click="SaveConfirmYes_Click"/>
                    <Button Style="{StaticResource PillBtn}"
                            Content="No"
                            Width="100" Height="34"
                            FontSize="13"
                            Background="#CC404055"
                            Click="SaveConfirmNo_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── About overlay (center) ──────────────────────────────── -->
        <Border x:Name="InfoPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#F01a1a2e"
                CornerRadius="16"
                Padding="36,28"
                MinWidth="320"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel>
                <TextBlock Text="GlassPad"
                           Foreground="White"
                           FontSize="24"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Touchscreen → Gamepad Overlay"
                           Foreground="#AAC0D0FF"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           TextAlignment="Center"
                           Margin="0,0,0,14"/>
                <TextBlock Text="by Dansunmi"
                           Foreground="#AACCE0FF"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="github.com/dansunmi/GlassPad"
                           Foreground="#6688AACC"
                           FontSize="11"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="HIDMaestro SDK v1.3.15"
                           Foreground="#88A0B8C8"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="GlassPad v1.0.0"
                           Foreground="#88A0B8C8"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,22"/>
                <Button Style="{StaticResource PillBtn}"
                        Content="Close"
                        Width="120" Height="34"
                        FontSize="13"
                        Background="#CC404055"
                        HorizontalAlignment="Center"
                        Click="InfoClose_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
